{
  "name": "agent-saas",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm run dev:server\" \"pnpm run dev:web\"",
    "dev:server": "pnpm -F server dev",
    "dev:web": "pnpm -F web dev",
    "dev:backend": "pnpm run dev:server",
    "dev:frontend": "pnpm run dev:web",
    "install:all": "pnpm install",
    "frpc:stop": "launchctl unload ~/Library/LaunchAgents/com.frp.frpc.plist 2>/dev/null; true",
    "frpc:start": "launchctl load ~/Library/LaunchAgents/com.frp.frpc.plist",
    "build": "pnpm -F web build",
    "start": "pnpm -F server start",
    "prod": "pnpm build && pnpm start",
    "dev:frpc": "pnpm run frpc:stop && concurrently -k -n server,web,frpc -c blue,green,yellow \"pnpm run dev:server\" \"pnpm run dev:web\" \"bash scripts/frpc.sh\"",
    "prod:frpc": "pnpm build && pnpm run frpc:stop && concurrently -k -n server,frpc -c blue,yellow \"pnpm start\" \"bash scripts/frpc.sh\"",
    "deploy": "bash scripts/deploy.sh",
    "test": "pnpm -r --filter='./server' --filter='./shared' --filter='./web' run --if-present test",
    "test:coverage": "pnpm -r --workspace-concurrency=1 --filter='./server' --filter='./shared' --filter='./web' run --if-present test:coverage",
    "coverage:summary": "node scripts/coverage-summary.mjs",
    "coverage:diff": "node scripts/coverage-diff.mjs",
    "typecheck": "pnpm -r --filter='./server' --filter='./shared' --filter='./web' run --if-present typecheck",
    "scenarios:lint": "pnpm -F server scenarios:lint",
    "scenarios:lint:fix": "pnpm -F server scenarios:lint:fix",
    "scenarios:sanitize-check": "pnpm -F server scenarios:sanitize-check",
    "scenarios:sanitize-check:fix": "pnpm -F server scenarios:sanitize-check:fix",
    "sanitize-check": "pnpm scenarios:sanitize-check",
    "rollback": "bash scripts/rollback.sh",
    "postinstall": "patch-package",
    "local:db": "docker compose -f docker-compose.local-db.yml up -d",
    "local:db:down": "docker compose -f docker-compose.local-db.yml down"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "patch-package": "^8.0.0"
  },
  "dependencies": {
    "expo": "~55.0.5",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "overrides": {
      "axios@1.13.4": "1.18.1",
      "form-data@4.0.5": "4.0.6",
      "hono@4.11.9": "4.12.30",
      "@hono/node-server@1.19.9": "1.19.14",
      "express-rate-limit@8.2.1": "8.6.0",
      "fast-uri@3.1.0": "3.1.3",
      "lodash@4.17.23": "4.18.1",
      "path-to-regexp@0.1.12": "0.1.13",
      "path-to-regexp@8.3.0": "8.4.0",
      "qs@6.14.1": "6.15.3"
    }
  }
}
