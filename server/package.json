{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    "./*.js": "./src/*.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch --watch-path=src/agent/descriptions src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "scenarios:lint": "tsx scripts/scenarios-lint.mjs",
    "scenarios:lint:fix": "tsx scripts/scenarios-lint.mjs --fix",
    "scenarios:sanitize-check": "tsx scripts/scenarios-sanitize-check.mjs",
    "scenarios:sanitize-check:fix": "tsx scripts/scenarios-sanitize-check.mjs --fix",
    "verify:restart-approval": "tsx scripts/verify-raw-runtime-restart-approval.mts",
    "verify:container-restart-approval": "tsx scripts/verify-raw-runtime-restart-approval.mts --execution-target server-container",
    "verify:container-smoke": "tsx scripts/verify-container-execution-ws.mts",
    "verify:tenant-container-smoke": "tsx scripts/verify-tenant-container-smoke.mts",
    "verify:audit-read": "tsx scripts/verify-runtime-audit-read.mts",
    "verify:server-remote-smoke": "tsx scripts/verify-server-remote-smoke.mts",
    "verify:pg-event-store": "tsx scripts/verify-pg-event-store.mts",
    "migrate:platform-tenant-pantheon": "tsx scripts/migrate-platform-tenant-pantheon.mts",
    "migrate:events-file-to-pg": "tsx scripts/migrate-events-file-to-pg.mts",
    "verify:chaos": "tsx scripts/verify-runtime-chaos.mts",
    "verify:chaos:hand-cancel": "tsx scripts/verify-runtime-chaos.mts --mode=hand-cancel",
    "verify:chaos:hand-kill": "tsx scripts/verify-runtime-chaos.mts --mode=hand-kill",
    "verify:chaos:server-restart": "tsx scripts/verify-runtime-chaos.mts --mode=server-restart",
    "verify:chaos:network-interrupt": "tsx scripts/verify-runtime-chaos.mts --mode=network-interrupt",
    "verify:chaos:multi-worker": "tsx scripts/verify-runtime-chaos.mts --mode=multi-worker",
    "verify:chaos:ask-user-resume": "tsx scripts/verify-runtime-chaos.mts --mode=ask-user-resume",
    "verify:chaos:client-daemon": "tsx scripts/verify-runtime-chaos.mts --mode=client-daemon",
    "verify:chaos:daemon-network": "tsx scripts/verify-runtime-chaos.mts --mode=daemon-network",
    "verify:chaos:renew-failure": "tsx scripts/verify-runtime-chaos.mts --mode=renew-failure",
    "verify:chaos:abort-states": "tsx scripts/verify-runtime-chaos.mts --mode=abort-states",
    "verify:chaos:notify-drop": "tsx scripts/verify-runtime-chaos.mts --mode=notify-drop",
    "verify:chaos:db-unavailable": "tsx scripts/verify-runtime-chaos.mts --mode=db-unavailable",
    "verify:chaos:gate": "tsx scripts/chaos-gate.mts",
    "verify:multiprocess:minimal": "tsx scripts/verify-runtime-multiprocess-minimal.mts",
    "verify:multiprocess:e2e": "tsx scripts/verify-runtime-multiprocess-e2e.mts --scenario=e2e",
    "verify:multiprocess:approval-resume": "tsx scripts/verify-runtime-multiprocess-approval-resume.mts",
    "verify:chaos:multiprocess:notify-drop": "tsx scripts/verify-runtime-chaos-notify-drop-multiprocess.mts",
    "verify:chaos:multiprocess:db-unavailable": "tsx scripts/verify-runtime-chaos-db-unavailable-multiprocess.mts",
    "verify:chaos:multiprocess:scheduler-restart": "tsx scripts/verify-runtime-chaos-scheduler-restart-multiprocess.mts",
    "verify:chaos:multiprocess:hand-kill": "tsx scripts/verify-runtime-chaos-hand-kill-multiprocess.mts",
    "client-daemon": "tsx scripts/client-daemon.mts",
    "verify:client-daemon": "vitest run src/__tests__/clientDaemonProtocol.test.ts src/__tests__/clientDaemonGateway.test.ts src/__tests__/clientDaemonRunner.test.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.3-r.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "ali-oss": "^6.23.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "croner": "^9.1.0",
    "dingtalk-stream": "^2.1.4",
    "express": "^4.21.0",
    "fluent-ffmpeg": "^2.1.3",
    "ipaddr.js": "^2.4.0",
    "jsonc-parser": "^3.3.1",
    "jsonwebtoken": "^9.0.3",
    "linkedom": "^0.18.12",
    "multer": "^2.0.2",
    "openai": "6.42.0",
    "pg": "^8.21.0",
    "playwright": "^1.49.0",
    "sqlite-vec": "^0.1.7",
    "sqlite-vec-darwin-arm64": "^0.1.7",
    "turndown": "^7.2.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
